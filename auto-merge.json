{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>ervwalter/renovate-config:default"],
  "packageRules": [
    {
      "description": "GitHub Actions major updates: auto-merge via label, no assignee",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "addLabels": ["automerge"],
      "assignees": []
    },
    {
      "description": "Non-major: auto-merge via label, no assignee (avoid notification spam)",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest"],
      "addLabels": ["automerge"],
      "assignees": []
    },
    {
      "description": "Security: same fast-track + auto-merge, no assignee",
      "matchCategories": ["security"],
      "addLabels": ["automerge"],
      "assignees": []
    },
    {
      "description": "Lock file maintenance: auto-merge via label, no assignee",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "addLabels": ["automerge"],
      "assignees": []
    }
  ]
}
